DATABASE_URL="postgresql://postgres:postgres@localhost:5432/minimal_list"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/minimal_list"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-secure-random-string-in-production"

# Site settings
NEXT_PUBLIC_SITE_NAME="Minimal List"
NEXT_PUBLIC_SITE_OWNER="Your Name"
NEXT_PUBLIC_SITE_DESCRIPTION="A clean personal list site for things worth keeping track of."
NEXT_PUBLIC_SITE_ABOUT="Inspired by Curated Supply: a personal list of items you like, want to buy, or want to keep track of."

# Feature flags
NEXT_PUBLIC_ENABLE_POSTERS="true"
NEXT_PUBLIC_ENABLE_MUSIC="false"
NEXT_PUBLIC_ENABLE_AI="false"

# Admin credentials (used for seeding)
ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="your-admin-password"

# Supabase storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="minimal-list"

# AI providers — AI routes try OpenRouter first, fall back to Gemini direct.
# Set OPENROUTER_API_KEY as the primary; keep GEMINI_API_KEY as the fallback (or omit either).
# Only needed when NEXT_PUBLIC_ENABLE_AI is true.
OPENROUTER_API_KEY="your-openrouter-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
